<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:styles="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0">
    <Grid Background="{DynamicResource {x:Static styles:VsBrushes.ToolWindowBackgroundKey}}"
          TextElement.Foreground="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}">
        <Grid.Resources>
            <!-- Remote UI XAML can't load Microsoft.VisualStudio.Shell.UI.Internal's
                 CommonControls.xaml via pack URI, so we apply VsBrushes directly to
                 default control templates. This keeps controls aligned with the
                 active VS theme without depending on internal style keys. -->
            <!-- VsBrushes does not expose ComboBox*Key entries, so we reuse the
                 tool-window surface/text/border keys, which are guaranteed to be
                 present in every VS theme. -->
            <!-- The default WPF ComboBox template ignores Background setters because
                 its inner ToggleButton paints native ComboBoxChrome. In Remote UI
                 we don't get VS's auto theme-replacement for combo boxes either,
                 so a minimal explicit template is required to get a dark surface
                 (closed control, drop arrow, popup, and items) instead of the
                 white system default. -->
            <Style x:Key="SharpClawComboBoxItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
                <Setter Property="Padding" Value="6,3" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource {x:Static styles:VsBrushes.CommandBarMouseOverBackgroundBeginKey}}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{DynamicResource {x:Static styles:VsBrushes.ComboBoxBackgroundKey}}" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static styles:VsBrushes.ComboBoxBorderKey}}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="MinHeight" Value="24" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource SharpClawComboBoxItemStyle}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.ColumnSpan="2"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" />

                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  IsHitTestVisible="False"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />

                                <ToggleButton Grid.Column="1"
                                              Focusable="False"
                                              ClickMode="Press"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}">
                                                <Path HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                    <Border MinWidth="{TemplateBinding ActualWidth}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            Background="{DynamicResource {x:Static styles:VsBrushes.ComboBoxPopupBackgroundBeginKey}}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1">
                                        <ScrollViewer>
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowBackgroundKey}}" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static styles:VsBrushes.CommandBarBorderKey}}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="CaretBrush" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource {x:Static styles:VsBrushes.ButtonFaceKey}}" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static styles:VsBrushes.ButtonTextKey}}" />
                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static styles:VsBrushes.CommandBarBorderKey}}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="MinHeight" Value="24" />
            </Style>

            <Style x:Key="ConnectedOnlyBorderStyle" TargetType="Border">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ConnectedOnlyGridStyle" TargetType="Grid">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DisconnectedOnlyBorderStyle" TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Disconnected state. Do not show selectors/transcript/composer
             until the backend has been successfully validated by Connect. -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Style="{StaticResource DisconnectedOnlyBorderStyle}"
                Padding="28"
                Background="{DynamicResource {x:Static styles:VsBrushes.ToolWindowBackgroundKey}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="540">
                <TextBlock Text="{Binding Status}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10" />
                <TextBlock Text="To see SharpClaw chat, first connect to a running SharpClaw backend."
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static styles:VsBrushes.GrayTextKey}}"
                           Margin="0,0,0,6" />
                <TextBlock Text="Connection options can be managed from Tools > SharpClaw > Options."
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           FontSize="10"
                           Foreground="{DynamicResource {x:Static styles:VsBrushes.GrayTextKey}}"
                           Margin="0,0,0,18" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button Content="Connect"
                            MinWidth="96"
                            Margin="0,0,8,0"
                            Command="{Binding ConnectCommand}" />
                    <Button Content="Open options"
                            MinWidth="112"
                            Command="{Binding OpenOptionsCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Selector strip -->
        <Border Grid.Row="0" Padding="8"
                Style="{StaticResource ConnectedOnlyBorderStyle}"
                Background="{DynamicResource {x:Static styles:VsBrushes.CommandBarGradientBeginKey}}"
                BorderBrush="{DynamicResource {x:Static styles:VsBrushes.CommandBarBorderKey}}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Row="0" Grid.Column="0" Margin="0,0,4,0"
                          ItemsSource="{Binding Contexts}"
                          SelectedIndex="{Binding SelectedContextIndex, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          ToolTip="Context" />

                <ComboBox Grid.Row="0" Grid.Column="1" Margin="4,0"
                          ItemsSource="{Binding Channels}"
                          SelectedIndex="{Binding SelectedChannelIndex, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          ToolTip="Channel" />

                <Grid Grid.Row="0" Grid.Column="2" Margin="4,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Threads}"
                              SelectedIndex="{Binding SelectedThreadIndex, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              ToolTip="Thread" />

                    <Button Grid.Column="1" Margin="4,0,0,0"
                            Padding="10,2" MinWidth="72"
                            Content="Reload"
                            ToolTip="Reload the selected thread"
                            IsEnabled="{Binding OpenThreadCommand.RunningCommandsCount.IsZero}"
                            Command="{Binding OpenThreadCommand}" />
                </Grid>

                <!-- Explanatory subtitles so users know which selectors require
                     creating the resource in SharpClaw vs. inline here. -->
                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,2,4,0"
                           FontSize="10" TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static styles:VsBrushes.GrayTextKey}}"
                           Text="{Binding ContextHint}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Margin="4,2"
                           FontSize="10" TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static styles:VsBrushes.GrayTextKey}}"
                           Text="{Binding ChannelHint}" />
                <TextBlock Grid.Row="1" Grid.Column="2" Margin="4,2,0,0"
                           FontSize="10" TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static styles:VsBrushes.GrayTextKey}}"
                           Text="{Binding ThreadHint}" />

                <!-- Inline thread creation: name + "+" button. Channels and
                     contexts must be created in SharpClaw because their
                     permissions can only be configured there. -->
                <Grid Grid.Row="2" Grid.Column="2" Margin="4,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding NewThreadName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="New thread name" />

                    <Button Grid.Column="1" Margin="4,0,0,0"
                            Padding="10,2" MinWidth="28"
                            Content="+"
                            ToolTip="Create thread on the selected channel"
                            Command="{Binding CreateThreadCommand}" />
                </Grid>
            </Grid>
        </Border>

        <!-- Transcript. Keep this as a single XamlFragment payload rather
             than a remote observable collection: loading a thread should
             produce one Remote UI property update, not a burst of item
             container realization work inside the Visual Studio process. -->
        <Border Grid.Row="1"
                Style="{StaticResource ConnectedOnlyBorderStyle}"
                Padding="8"
                Background="{DynamicResource {x:Static styles:VsBrushes.ToolWindowBackgroundKey}}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ContentControl Content="{Binding TranscriptContent}" />
            </ScrollViewer>
        </Border>

        <!-- Composer -->
        <Grid Grid.Row="2" Margin="8"
              Style="{StaticResource ConnectedOnlyGridStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding Composer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"
                     MaxHeight="160"
                     VerticalScrollBarVisibility="Auto" />

            <Button Grid.Column="1" Margin="8,0,0,0"
                    Padding="16,4"
                    VerticalAlignment="Stretch"
                    MinHeight="60"
                    Content="Send"
                    IsEnabled="{Binding CanSend}"
                    Command="{Binding SendCommand}" />
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Padding="8,4"
                Background="{DynamicResource {x:Static styles:VsBrushes.CommandBarGradientBeginKey}}"
                BorderBrush="{DynamicResource {x:Static styles:VsBrushes.CommandBarBorderKey}}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding Status}"
                       Foreground="{DynamicResource {x:Static styles:VsBrushes.GrayTextKey}}" />
        </Border>
    </Grid>
</DataTemplate>
