<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:styles="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0">
    <Grid Background="{DynamicResource {x:Static styles:VsBrushes.ToolWindowBackgroundKey}}"
          TextElement.Foreground="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}">
        <Grid.Resources>
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowBackgroundKey}}" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static styles:VsBrushes.CommandBarBorderKey}}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="CaretBrush" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
            </Style>

            <Style x:Key="SharpClawComboBoxItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
                <Setter Property="Padding" Value="6,3" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource {x:Static styles:VsBrushes.CommandBarMouseOverBackgroundBeginKey}}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource {x:Static styles:VsBrushes.CommandBarSelectedKey}}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{DynamicResource {x:Static styles:VsBrushes.ComboBoxBackgroundKey}}" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static styles:VsBrushes.ComboBoxBorderKey}}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="6,3" />
                <Setter Property="MinHeight" Value="26" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource SharpClawComboBoxItemStyle}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="22" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.ColumnSpan="2"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" />

                                <ContentPresenter Grid.Column="0"
                                                  Margin="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  IsHitTestVisible="False"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />

                                <ToggleButton Grid.Column="1"
                                              Focusable="False"
                                              ClickMode="Press"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}">
                                                <Path HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                    <Border MinWidth="{TemplateBinding ActualWidth}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            Background="{DynamicResource {x:Static styles:VsBrushes.ComboBoxPopupBackgroundBeginKey}}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1">
                                        <ScrollViewer>
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource {x:Static styles:VsBrushes.ButtonFaceKey}}" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static styles:VsBrushes.ButtonTextKey}}" />
                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static styles:VsBrushes.CommandBarBorderKey}}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,5" />
                <Setter Property="MinHeight" Value="26" />
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource {x:Static styles:VsBrushes.ToolWindowTextKey}}" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Background="{DynamicResource {x:Static styles:VsBrushes.CommandBarGradientBeginKey}}"
                BorderBrush="{DynamicResource {x:Static styles:VsBrushes.CommandBarBorderKey}}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="SharpClaw connection options"
                           FontSize="15"
                           FontWeight="SemiBold" />
                <TextBlock Text="Select a detected backend instance, or override the endpoint and authentication material used by Connect."
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource {x:Static styles:VsBrushes.GrayTextKey}}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Border Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Margin="0,0,12,6"
                           VerticalAlignment="Center"
                           Text="Detected backend" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          Margin="0,0,0,6"
                          ItemsSource="{Binding DetectedInstances}"
                          SelectedIndex="{Binding SelectedInstanceIndex, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName" />

                <TextBlock Grid.Row="1" Grid.Column="1"
                           Margin="0,0,0,14"
                           TextWrapping="Wrap"
                           FontSize="10"
                           Foreground="{DynamicResource {x:Static styles:VsBrushes.GrayTextKey}}"
                           Text="Auto-select uses SharpClaw discovery ranking. Choosing an instance pins Connect to that backend unless it disappears, in which case discovery falls back to the best available instance." />

                <CheckBox Grid.Row="2" Grid.Column="1"
                          Margin="0,0,0,16"
                          Content="Prefer running backend processes when sorting detected instances"
                          IsChecked="{Binding PreferAliveInstances, Mode=TwoWay}" />

                <TextBlock Grid.Row="3" Grid.Column="0"
                           Margin="0,0,12,8"
                           VerticalAlignment="Center"
                           Text="Base URL override" />
                <TextBox Grid.Row="3" Grid.Column="1"
                         Margin="0,0,0,8"
                         Text="{Binding BaseUrlOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Example: http://127.0.0.1:48923" />

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Margin="0,0,12,8"
                           VerticalAlignment="Center"
                           Text="Port override" />
                <TextBox Grid.Row="4" Grid.Column="1"
                         Margin="0,0,0,8"
                         Text="{Binding PortOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Overrides only the port on the selected or manual Base URL." />

                <TextBlock Grid.Row="5" Grid.Column="0"
                           Margin="0,0,12,8"
                           VerticalAlignment="Center"
                           Text="API key override" />
                <TextBox Grid.Row="5" Grid.Column="1"
                         Margin="0,0,0,8"
                         Text="{Binding ApiKeyOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Stored locally in the VS2026 extension options file." />

                <TextBlock Grid.Row="6" Grid.Column="0"
                           Margin="0,0,12,8"
                           VerticalAlignment="Center"
                           Text="API key file override" />
                <TextBox Grid.Row="6" Grid.Column="1"
                         Margin="0,0,0,8"
                         Text="{Binding ApiKeyFileOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="7" Grid.Column="0"
                           Margin="0,0,12,8"
                           VerticalAlignment="Center"
                           Text="Gateway token override" />
                <TextBox Grid.Row="7" Grid.Column="1"
                         Margin="0,0,0,8"
                         Text="{Binding GatewayTokenOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Stored locally in the VS2026 extension options file." />

                <TextBlock Grid.Row="8" Grid.Column="0"
                           Margin="0,0,12,8"
                           VerticalAlignment="Center"
                           Text="Gateway token file override" />
                <TextBox Grid.Row="8" Grid.Column="1"
                         Margin="0,0,0,8"
                         Text="{Binding GatewayTokenFileOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Grid.Row="9" Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,12,0,0">
                    <Button Content="Refresh detected"
                            Margin="0,0,8,0"
                            Command="{Binding RefreshCommand}" />
                    <Button Content="Reset"
                            Margin="0,0,8,0"
                            Command="{Binding ResetCommand}" />
                    <Button Content="Save"
                            Margin="0,0,8,0"
                            Command="{Binding SaveCommand}" />
                    <Button Content="Save and connect"
                            Command="{Binding ConnectCommand}" />
                </StackPanel>
            </Grid>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="8,4"
                Background="{DynamicResource {x:Static styles:VsBrushes.CommandBarGradientBeginKey}}"
                BorderBrush="{DynamicResource {x:Static styles:VsBrushes.CommandBarBorderKey}}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding Status}"
                       Foreground="{DynamicResource {x:Static styles:VsBrushes.GrayTextKey}}"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</DataTemplate>
